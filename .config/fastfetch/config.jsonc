{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "modules": [
    "title",
    {
	"type": "custom",
	"format": "harikkite ikou!!!",
	"outputColor": "magenta"
    },
    "separator",
    {
	"type": "os",
	"format": "{pretty-name} btw"
    },
    "host",
    "kernel",
    "uptime",
    "packages",
    "wm"
  ],

  "logo": {
	"type": "kitty",
	"source": "~/.config/fastfetch/kitasanblack_doodles.jpg",
	"width": 15
  }
}
